      "item": [
        {
          "name": "00.1 Crear curso base para examen",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": "{{ec2Url}}/cursos",
            "description": "No grabar. Crea el curso que se usara para inscripcion e intento.",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{instructorToken}}",
                  "type": "string"
                }
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Curso base demo Kaltura\",\n  \"instructor\": \"Docente CDY2204\",\n  \"duracion\": \"24 horas\",\n  \"costo\": 120000\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const token = pm.collectionVariables.get('instructorToken');",
                  "if (!token || !token.trim()) { throw new Error('Falta instructorToken. Pega un JWT vigente sin la palabra Bearer.'); }"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Curso base creado', function () { pm.response.to.have.status(201); });",
                  "const data = pm.response.json();",
                  "pm.collectionVariables.set('cursoId', String(data.id));"
                ]
              }
            }
          ]
        },
