{
  "info": {
    "name": "CDY2204 Semana 7 - RabbitMQ EC2",
    "description": "Pruebas Postman para RabbitMQ Management API en EC2. Usar Basic Auth guest/guest.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "basic",
    "basic": [
      {
        "key": "username",
        "value": "{{rabbitUser}}",
        "type": "string"
      },
      {
        "key": "password",
        "value": "{{rabbitPassword}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "rabbitUrl",
      "value": "http://107.23.174.145:15672"
    },
    {
      "key": "rabbitUser",
      "value": "guest"
    },
    {
      "key": "rabbitPassword",
      "value": "guest"
    },
    {
      "key": "queueName",
      "value": "myQueue"
    },
    {
      "key": "exchangeName",
      "value": "myExchange"
    },
    {
      "key": "routingKey",
      "value": "myKey"
    }
  ],
  "item": [
    {
      "name": "01 Verificar RabbitMQ activo",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 OK', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const data = pm.response.json();",
              "pm.test('RabbitMQ responde con version', function () {",
              "  pm.expect(data.rabbitmq_version).to.exist;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": "{{rabbitUrl}}/api/overview",
        "description": "Evidencia: RabbitMQ Management API responde desde EC2."
      }
    },
    {
      "name": "02 Crear cola myQueue",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 201 o 204', function () {",
              "  pm.expect([201, 204]).to.include(pm.response.code);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"durable\": true\n}"
        },
        "url": "{{rabbitUrl}}/api/queues/%2F/{{queueName}}",
        "description": "Evidencia: cola durable creada en virtual host /."
      }
    },
    {
      "name": "03 Crear exchange myExchange",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 201 o 204', function () {",
              "  pm.expect([201, 204]).to.include(pm.response.code);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"type\": \"direct\",\n  \"durable\": true\n}"
        },
        "url": "{{rabbitUrl}}/api/exchanges/%2F/{{exchangeName}}",
        "description": "Evidencia: exchange directo creado."
      }
    },
    {
      "name": "04 Crear binding exchange a cola",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 201 Created', function () {",
              "  pm.response.to.have.status(201);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"routing_key\": \"{{routingKey}}\",\n  \"arguments\": {}\n}"
        },
        "url": "{{rabbitUrl}}/api/bindings/%2F/e/{{exchangeName}}/q/{{queueName}}",
        "description": "Evidencia: binding con routing key myKey."
      }
    },
    {
      "name": "05 Publicar mensaje",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 OK', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const data = pm.response.json();",
              "pm.test('Mensaje enrutado a la cola', function () {",
              "  pm.expect(data.routed).to.eql(true);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"properties\": {},\n  \"routing_key\": \"{{routingKey}}\",\n  \"payload\": \"prueba semana 7 desde Postman\",\n  \"payload_encoding\": \"string\"\n}"
        },
        "url": "{{rabbitUrl}}/api/exchanges/%2F/{{exchangeName}}/publish",
        "description": "Evidencia: mensaje publicado desde Postman hacia RabbitMQ."
      }
    },
    {
      "name": "06 Consumir mensaje desde cola",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 OK', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const data = pm.response.json();",
              "pm.test('Respuesta es una lista', function () {",
              "  pm.expect(data).to.be.an('array');",
              "});",
              "pm.test('Mensaje recibido', function () {",
              "  pm.expect(data.length).to.be.greaterThan(0);",
              "  pm.expect(data[0].payload).to.include('prueba semana 7');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"count\": 1,\n  \"ackmode\": \"ack_requeue_false\",\n  \"encoding\": \"auto\",\n  \"truncate\": 50000\n}"
        },
        "url": "{{rabbitUrl}}/api/queues/%2F/{{queueName}}/get",
        "description": "Evidencia: mensaje consumido desde la cola. Esta accion elimina el mensaje de la cola."
      }
    }
  ]
}
