  "item": [
    {
      "name": "00 - Seguridad e infraestructura base",
      "description": "Pruebas rapidas para demostrar proteccion JWT y disponibilidad base.",
      "item": [
        {
          "name": "00.1 EC2 sin token debe responder 401",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{ec2Url}}/cursos",
            "description": "Evidencia: Spring Security protege el backend directo.",
            "auth": {
              "type": "noauth"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Sin token responde 401 Unauthorized', function () { pm.response.to.have.status(401); });"
                ]
              }
            }
          ]
        },
        {
          "name": "00.2 EC2 con token debe responder 200",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{ec2Url}}/cursos",
            "description": "Evidencia: JWT Azure AD B2C es aceptado por Spring Security."
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const token = pm.collectionVariables.get('accessToken');",
                  "if (!token || token.includes('PEGAR_')) {",
                  "  throw new Error('Falta accessToken. Pega un JWT vigente de Azure AD B2C en variables de la coleccion.');",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Con token responde 200 OK', function () { pm.response.to.have.status(200); });",
                  "pm.test('Respuesta JSON', function () { pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json'); });"
                ]
              }
            }
          ]
        },
        {
          "name": "00.3 API Gateway sin token debe responder 401",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{apiGatewayUrl}}/cursos",
            "description": "Evidencia opcional: API Gateway enruta hacia backend protegido. Si no se usa Gateway, omitir.",
            "auth": {
              "type": "noauth"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Sin token responde 401 Unauthorized', function () { pm.response.to.have.status(401); });"
                ]
              }
            }
          ]
        },
        {
          "name": "00.4 API Gateway con token debe responder 200",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{apiGatewayUrl}}/cursos",
            "description": "Evidencia opcional: endpoints publicados en API Gateway con JWT."
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const token = pm.collectionVariables.get('accessToken');",
                  "if (!token || token.includes('PEGAR_')) {",
                  "  throw new Error('Falta accessToken. Pega un JWT vigente de Azure AD B2C en variables de la coleccion.');",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Con token responde 200 OK', function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ]
        }
      ]
    },
