                "value": "application/json",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/cursos",
            "description": "Evidencia: microservicio Spring Boot devuelve JSON y persiste curso en Oracle.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"EFT Cloud Native Spring Boot\",\n  \"instructor\": \"Docente CDY2204\",\n  \"duracion\": \"24 horas\",\n  \"costo\": 120000\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const token = pm.collectionVariables.get('accessToken');",
                  "if (!token || token.includes('PEGAR_')) {",
                  "  throw new Error('Falta accessToken. Pega un JWT vigente de Azure AD B2C en variables de la coleccion.');",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201 Created', function () { pm.response.to.have.status(201); });",
                  "const data = pm.response.json();",
                  "pm.test('Curso creado con id', function () { pm.expect(data.id).to.exist; });",
                  "pm.collectionVariables.set('cursoId', String(data.id));"
                ]
              }
            }
