{
  "info": {
    "name": "CDY2204 Semana 5 - Reutilizacion Semana 4 + Spring Security",
    "description": "Coleccion minima para evidenciar Semana 5 reutilizando Semana 4: EC2 protegido con Spring Security, API Gateway reutilizado y Azure AD B2C como IDaaS.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "apiGatewayUrl",
      "value": "https://f3k22g500d.execute-api.us-east-1.amazonaws.com",
      "description": "URL de invocacion de API Gateway."
    },
    {
      "key": "ec2BackendUrl",
      "value": "http://107.23.174.145:8080",
      "description": "URL directa del backend Spring Boot en EC2."
    },
    {
      "key": "accessToken",
      "value": "",
      "description": "JWT vigente emitido por Azure AD B2C. Pegar solo el token, sin Bearer."
    },
    {
      "key": "cursoId",
      "value": "1",
      "description": "Se actualiza al crear curso demo."
    },
    {
      "key": "numeroResumen",
      "value": "1",
      "description": "Se actualiza al crear inscripcion demo."
    }
  ],
  "item": [
    {
      "name": "00 - Backend EC2 securitizado sin token",
      "description": "Demuestra que Spring Security protege el backend directo en EC2.",
      "item": [
        {
          "name": "00.1 EC2 - Listar cursos sin token",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{ec2BackendUrl}}/cursos",
            "description": "Debe responder 401 por Spring Security."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Sin token responde 401 Unauthorized', function () {",
                  "  pm.response.to.have.status(401);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "01 - API Gateway sin token",
      "description": "Demuestra que API Gateway reutilizado de Semana 4 bloquea llamadas sin JWT.",
      "item": [
        {
          "name": "01.1 Cursos - Listar sin token",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{apiGatewayUrl}}/cursos",
            "description": "Debe responder 401 sin JWT."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Sin token responde 401 Unauthorized', function () {",
                  "  pm.response.to.have.status(401);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "01.2 S3 - Descargar resumen sin token",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{apiGatewayUrl}}/s3/downloadResumen?numeroResumen={{numeroResumen}}",
            "description": "Debe responder 401 sin JWT."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Sin token responde 401 Unauthorized', function () {",
                  "  pm.response.to.have.status(401);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "02 - API Gateway con token Azure AD B2C",
      "description": "Demuestra que los endpoints funcionan con un JWT vigente de Azure AD B2C.",
      "item": [
        {
          "name": "02.1 Cursos - Listar",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text",
                "description": "JWT emitido por Azure AD B2C"
              }
            ],
            "url": "{{apiGatewayUrl}}/cursos",
            "description": "Lista cursos por API Gateway con JWT."
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const token = pm.collectionVariables.get('accessToken');",
                  "if (!token) {",
                  "  throw new Error('Falta accessToken. Pega el JWT de Azure AD B2C antes de continuar.');",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Con token responde 200 OK', function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ]
        },
        {
          "name": "02.2 Cursos - Crear",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text",
                "description": "JWT emitido por Azure AD B2C"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{apiGatewayUrl}}/cursos",
            "description": "Crea curso por API Gateway con JWT.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Semana 5 Spring Security Demo\",\n  \"instructor\": \"Docente CDY2204\",\n  \"duracion\": \"24 horas\",\n  \"costo\": 120000\n}"
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const token = pm.collectionVariables.get('accessToken');",
                  "if (!token) {",
                  "  throw new Error('Falta accessToken. Pega el JWT de Azure AD B2C antes de continuar.');",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Curso creado con 201 Created', function () { pm.response.to.have.status(201); });",
                  "const data = pm.response.json();",
                  "pm.collectionVariables.set('cursoId', String(data.id));"
                ]
              }
            }
          ]
        },
        {
          "name": "02.3 Inscripciones - Crear",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text",
                "description": "JWT emitido por Azure AD B2C"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{apiGatewayUrl}}/inscripciones",
            "description": "Crea inscripcion por API Gateway con JWT.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"estudianteNombre\": \"Estudiante Demo Semana 5\",\n  \"estudianteEmail\": \"demo.semana5@duocuc.cl\",\n  \"cursoIds\": [{{cursoId}}]\n}"
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const token = pm.collectionVariables.get('accessToken');",
                  "if (!token) {",
                  "  throw new Error('Falta accessToken. Pega el JWT de Azure AD B2C antes de continuar.');",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Inscripcion creada con 201 Created', function () { pm.response.to.have.status(201); });",
                  "const data = pm.response.json();",
                  "pm.collectionVariables.set('numeroResumen', String(data.id));"
                ]
              }
            }
          ]
        },
        {
          "name": "02.4 Resumen local - Descargar",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text",
                "description": "JWT emitido por Azure AD B2C"
              }
            ],
            "url": "{{apiGatewayUrl}}/inscripciones/{{numeroResumen}}/resumen",
            "description": "Descarga resumen generado por Spring Boot."
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const token = pm.collectionVariables.get('accessToken');",
                  "if (!token) {",
                  "  throw new Error('Falta accessToken. Pega el JWT de Azure AD B2C antes de continuar.');",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Con token responde 200 OK', function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ]
        },
        {
          "name": "02.5 S3 - Subir resumen",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text",
                "description": "JWT emitido por Azure AD B2C"
              }
            ],
            "url": "{{apiGatewayUrl}}/s3/uploadResumen?numeroResumen={{numeroResumen}}",
            "description": "Sube resumen a S3."
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const token = pm.collectionVariables.get('accessToken');",
                  "if (!token) {",
                  "  throw new Error('Falta accessToken. Pega el JWT de Azure AD B2C antes de continuar.');",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Con token responde 200 OK', function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ]
        },
        {
          "name": "02.6 S3 - Actualizar resumen",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text",
                "description": "JWT emitido por Azure AD B2C"
              }
            ],
            "url": "{{apiGatewayUrl}}/s3/updateResumen?numeroResumen={{numeroResumen}}",
            "description": "Actualiza resumen en S3."
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const token = pm.collectionVariables.get('accessToken');",
                  "if (!token) {",
                  "  throw new Error('Falta accessToken. Pega el JWT de Azure AD B2C antes de continuar.');",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Con token responde 200 OK', function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ]
        },
        {
          "name": "02.7 S3 - Descargar resumen",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text",
                "description": "JWT emitido por Azure AD B2C"
              }
            ],
            "url": "{{apiGatewayUrl}}/s3/downloadResumen?numeroResumen={{numeroResumen}}",
            "description": "Descarga resumen desde S3."
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const token = pm.collectionVariables.get('accessToken');",
                  "if (!token) {",
                  "  throw new Error('Falta accessToken. Pega el JWT de Azure AD B2C antes de continuar.');",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Con token responde 200 OK', function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ]
        },
        {
          "name": "02.8 S3 - Eliminar resumen",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text",
                "description": "JWT emitido por Azure AD B2C"
              }
            ],
            "url": "{{apiGatewayUrl}}/s3/deleteResumen?numeroResumen={{numeroResumen}}",
            "description": "Elimina resumen desde S3."
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const token = pm.collectionVariables.get('accessToken');",
                  "if (!token) {",
                  "  throw new Error('Falta accessToken. Pega el JWT de Azure AD B2C antes de continuar.');",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Con token responde 200 OK', function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
