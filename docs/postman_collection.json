{
  "info": {
    "name": "CDY2204 Formativa Cloud Native - Evidencias",
    "description": "Coleccion preparada para capturar evidencias en orden. Ejecutar desde arriba hacia abajo. Las respuestas exitosas guardan automaticamente cursoId y numeroResumen.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://107.23.174.145:8080"
    },
    {
      "key": "cursoId",
      "value": "1"
    },
    {
      "key": "numeroResumen",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "01 - Flujo principal para evidencia",
      "item": [
        {
          "name": "01 Crear curso",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201 Created', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const data = pm.response.json();",
                  "pm.test('Curso creado con ID', function () {",
                  "  pm.expect(data.id).to.exist;",
                  "});",
                  "",
                  "if (data.id) {",
                  "  pm.collectionVariables.set('cursoId', data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Spring Boot Cloud Native\",\n  \"instructor\": \"Docente CDY2204\",\n  \"duracion\": \"24 horas\",\n  \"costo\": 120000\n}"
            },
            "url": "{{baseUrl}}/cursos",
            "description": "Evidencia: curso persistido en Oracle Cloud. Capturar status 201 y body con id."
          }
        },
        {
          "name": "02 Listar cursos",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const data = pm.response.json();",
                  "pm.test('Respuesta es una lista con cursos', function () {",
                  "  pm.expect(data).to.be.an('array');",
                  "  pm.expect(data.length).to.be.greaterThan(0);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/cursos",
            "description": "Evidencia: consulta de cursos disponibles desde Oracle Cloud."
          }
        },
        {
          "name": "03 Crear inscripcion",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201 Created', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const data = pm.response.json();",
                  "pm.test('Inscripcion creada con total', function () {",
                  "  pm.expect(data.inscripcionId).to.exist;",
                  "  pm.expect(Number(data.totalPagar)).to.be.greaterThan(0);",
                  "});",
                  "",
                  "if (data.inscripcionId) {",
                  "  pm.collectionVariables.set('numeroResumen', data.inscripcionId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"estudianteNombre\": \"Maria Perez\",\n  \"estudianteEmail\": \"maria.perez@duocuc.cl\",\n  \"cursoIds\": [{{cursoId}}]\n}"
            },
            "url": "{{baseUrl}}/inscripciones",
            "description": "Evidencia: inscripcion persistida, cursos asociados y total calculado."
          }
        },
        {
          "name": "04 Descargar resumen local",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Respuesta de texto con resumen', function () {",
                  "  pm.expect(pm.response.text()).to.include('Maria Perez');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/inscripciones/{{numeroResumen}}/resumen",
            "description": "Evidencia: archivo fisico resumen.txt generado y descargado."
          }
        },
        {
          "name": "05 S3 - Subir resumen generado",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const data = pm.response.json();",
                  "pm.test('Objeto S3 creado con clave de resumen', function () {",
                  "  pm.expect(data.bucket).to.exist;",
                  "  pm.expect(data.clave).to.eql(pm.collectionVariables.get('numeroResumen') + '/resumen.txt');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/s3/uploadResumen?numeroResumen={{numeroResumen}}",
            "description": "Evidencia: resumen subido a S3 en carpeta numeroResumen/resumen.txt."
          }
        },
        {
          "name": "06 S3 - Actualizar resumen generado",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const data = pm.response.json();",
                  "pm.test('Objeto S3 actualizado', function () {",
                  "  pm.expect(data.clave).to.eql(pm.collectionVariables.get('numeroResumen') + '/resumen.txt');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/s3/updateResumen?numeroResumen={{numeroResumen}}",
            "description": "Evidencia: reemplazo del resumen existente en S3."
          }
        },
        {
          "name": "07 S3 - Descargar resumen",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Descarga contiene datos del estudiante', function () {",
                  "  pm.expect(pm.response.text()).to.include('Maria Perez');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/s3/downloadResumen?numeroResumen={{numeroResumen}}",
            "description": "Evidencia: descarga del archivo almacenado en S3."
          }
        },
        {
          "name": "08 S3 - Eliminar resumen",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const data = pm.response.json();",
                  "pm.test('Objeto S3 eliminado', function () {",
                  "  pm.expect(data.clave).to.eql(pm.collectionVariables.get('numeroResumen') + '/resumen.txt');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/s3/deleteResumen?numeroResumen={{numeroResumen}}",
            "description": "Evidencia: eliminacion del objeto en S3."
          }
        }
      ]
    },
    {
      "name": "02 - Evidencias de validacion y errores",
      "item": [
        {
          "name": "09 Error validacion - Curso sin nombre",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400 Bad Request', function () {",
                  "  pm.response.to.have.status(400);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"\",\n  \"instructor\": \"Docente CDY2204\",\n  \"duracion\": \"24 horas\",\n  \"costo\": 120000\n}"
            },
            "url": "{{baseUrl}}/cursos",
            "description": "Evidencia opcional: validacion de datos de entrada."
          }
        },
        {
          "name": "10 Error negocio - Curso inexistente",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404 Not Found', function () {",
                  "  pm.response.to.have.status(404);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"estudianteNombre\": \"Juan Soto\",\n  \"estudianteEmail\": \"juan.soto@duocuc.cl\",\n  \"cursoIds\": [999999]\n}"
            },
            "url": "{{baseUrl}}/inscripciones",
            "description": "Evidencia opcional: manejo controlado de recurso inexistente."
          }
        }
      ]
    }
  ]
}
